{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "IFSWeather.Api",
    "Audience": "IFSWeather.Client",
    "AccessTokenExpirationMinutes": 60,
    "SecretKey": ""
  },
  "WeatherApi": {
    "BaseUrl": "https://api.weatherapi.com/v1/",
    "TimeoutSeconds": 10,
    "MaximumForecastDays": 3
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "AdminBootstrap": {
    "Enabled": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
